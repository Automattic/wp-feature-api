{
  "name": "a8c/wp-feature-api",
  "type": "library",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Greg Hunt",
      "email": "gregory.hunt@automattic.com"
    }
  ],
  "require": {
    "ext-hash": "*",
    "ext-json": "*",
    "php": ">=7.4"
  },
  "suggest": {
    "ext-dom": "*"
  },
  "require-dev": {
    "composer/ca-bundle": "1.5.6",
    "squizlabs/php_codesniffer": "3.10.3",
    "wp-coding-standards/wpcs": "~3.1.0",
    "phpcompatibility/phpcompatibility-wp": "~2.1.3",
    "yoast/phpunit-polyfills": "^1.1.0",
    "10up/wp_mock": "^1.1"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "lock": false
  },
  "scripts": {
    "phpcs": "vendor/bin/phpcs -ps --standard=phpcs.xml.dist",
    "phpcbf": "vendor/bin/phpcbf -ps --standard=phpcs.xml.dist",
    "phpcs:compat": "vendor/bin/phpcs -ps --standard=PHPCompatibilityWP --runtime-set testVersion 7.0-",
    "phpcs:tests": "vendor/bin/phpcs -ps --standard=phpcs-tests.xml.dist",
    "phpcbf:tests": "vendor/bin/phpcbf -ps --standard=phpcs-tests.xml.dist",
    "phpcs:tests:compat": "vendor/bin/phpcs -ps --standard=PHPCompatibilityWP --runtime-set testVersion 7.4- ./tests",
    "lint": "@phpcs",
    "format": "@phpcbf",
    "lint:all": [
      "@phpcs",
      "@phpcs:compat",
      "@phpcs:tests",
      "@phpcs:tests:compat"
    ],
    "lint:file": "vendor/bin/phpcs -ps --standard=phpcs.xml.dist",
    "lint:test-file": "vendor/bin/phpcs -ps --standard=phpcs.xml",
    "test": "vendor/bin/phpunit",
    "serve": "npx @wp-now/wp-now start"
  }
}